# MCP Server A: Job Analysis + Assessment Generation
FROM python:3.11-slim

WORKDIR /app

# Install Python dependencies
COPY server-a-job-analysis/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copy server source code
COPY server-a-job-analysis/src ./src

# Set Python to unbuffered mode for stdio communication
ENV PYTHONUNBUFFERED=1

# Run as non-root user
RUN useradd -r -u 1001 -m mcpuser
USER mcpuser

CMD ["python3", "src/server.py"]